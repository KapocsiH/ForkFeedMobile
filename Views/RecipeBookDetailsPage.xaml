<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ForkFeedMobile.ViewModels"
             xmlns:models="clr-namespace:ForkFeedMobile.Models"
             xmlns:icons="clr-namespace:MauiIcons.FluentFilled;assembly=MauiIcons.FluentFilled"
             xmlns:controls="clr-namespace:ForkFeedMobile.Controls"
             x:Class="ForkFeedMobile.Views.RecipeBookDetailsPage"
             x:DataType="vm:RecipeBookDetailsViewModel"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="True"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource NavBarBackground}}">

    <Grid>
        <ScrollView IsVisible="{Binding IsNotLoading}">
            <VerticalStackLayout Padding="24,8,24,24" Spacing="12">

                <Label Text="{Binding ErrorMessage}"
                       TextColor="{StaticResource ErrorRed}"
                       FontSize="13"
                       IsVisible="{Binding HasError}"
                       HorizontalTextAlignment="Center" />

                <!-- Visibility tag + Edit button for own books -->
                <Grid IsVisible="{Binding IsOwn}"
                      ColumnDefinitions="Auto,*,Auto,Auto"
                      ColumnSpacing="8"
                      Margin="0,4,0,0">
                    <Border Grid.Column="0"
                            StrokeShape="RoundRectangle 12"
                            Stroke="{Binding VisibilityBorderColor}"
                            BackgroundColor="{Binding VisibilityBackgroundColor}"
                            Padding="10,4"
                            StrokeThickness="1.5"
                            VerticalOptions="Center">
                        <Label Text="{Binding VisibilityText}"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="White" />
                    </Border>
                    <Button Grid.Column="2"
                            Text="Szerkesztés"
                            Command="{Binding EditBookCommand}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            CornerRadius="12"
                            FontSize="13"
                            HeightRequest="36"
                            Padding="16,0" />
                    <Button Grid.Column="3"
                            Text="Törlés"
                            Command="{Binding DeleteBookCommand}"
                            BackgroundColor="{StaticResource ErrorRed}"
                            TextColor="White"
                            CornerRadius="12"
                            FontSize="13"
                            HeightRequest="36"
                            Padding="16,0" />
                </Grid>

                <CollectionView ItemsSource="{Binding Recipes}"
                                SelectionMode="None">

                    <CollectionView.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Padding="40">
                            <icons:MauiIcon Icon="Food24Filled" IconSize="48" HorizontalOptions="Center" />
                            <Label Text="Nincsenek receptek ebben a füzetben." FontSize="18"
                                   TextColor="{StaticResource Gray400}"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Recipe">
                            <Frame Margin="0,8" Padding="0" CornerRadius="12" HasShadow="True" BorderColor="Transparent"
                                   BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RecipeBookDetailsViewModel}}, Path=GoToRecipeDetailCommand}"
                                        CommandParameter="{Binding}" />
                                </Frame.GestureRecognizers>

                                <Grid>
                                    <VerticalStackLayout Padding="12" Spacing="4">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Grid.Column="0" Text="{Binding Title}"
                                                   FontSize="18" FontAttributes="Bold"
                                                   LineBreakMode="TailTruncation" />

                                            <icons:MauiIcon Grid.Column="1"
                                                   Icon="{Binding IsFavorite, Converter={StaticResource FavoriteIcon}}"
                                                   IconColor="{Binding IsFavorite, Converter={StaticResource FavoriteColor}}"
                                                   IconSize="24"
                                                   VerticalOptions="Center">
                                                <icons:MauiIcon.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RecipeBookDetailsViewModel}}, Path=ToggleFavoriteCommand}"
                                                        CommandParameter="{Binding}" />
                                                </icons:MauiIcon.GestureRecognizers>
                                            </icons:MauiIcon>
                                        </Grid>

                                        <HorizontalStackLayout Spacing="12">
                                            <Border StrokeShape="RoundRectangle 12"
                                                    Stroke="{Binding DifficultyBorderColor}"
                                                    BackgroundColor="{Binding DifficultyBackgroundColor}"
                                                    Padding="10,4"
                                                    StrokeThickness="1.5"
                                                    VerticalOptions="Center">
                                                <Label Text="{Binding DifficultyDisplay}"
                                                       FontSize="12"
                                                       FontAttributes="Bold"
                                                       TextColor="White" />
                                            </Border>
                                            <HorizontalStackLayout Spacing="4">
                                                <icons:MauiIcon Icon="Timer24Filled" IconSize="13" IconColor="{StaticResource Gray500}" VerticalOptions="Center" />
                                                <Label FontSize="13" TextColor="{StaticResource Gray500}" VerticalOptions="Center">
                                                    <Label.FormattedText>
                                                        <FormattedString>
                                                            <Span Text="{Binding TimeMinutes}" />
                                                            <Span Text=" min" />
                                                        </FormattedString>
                                                    </Label.FormattedText>
                                                </Label>
                                            </HorizontalStackLayout>
                                            <HorizontalStackLayout Spacing="4">
                                                <icons:MauiIcon Icon="Star12Filled" IconSize="13" IconColor="{StaticResource StarFilled}" VerticalOptions="Center" />
                                                <Label FontSize="13" TextColor="{StaticResource StarFilled}" VerticalOptions="Center">
                                                    <Label.FormattedText>
                                                        <FormattedString>
                                                            <Span Text="{Binding Rating, StringFormat='{0:F1}'}" />
                                                        </FormattedString>
                                                    </Label.FormattedText>
                                                </Label>
                                            </HorizontalStackLayout>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>
        <!-- Centered Loading Overlay -->
        <controls:LoadingOverlay IsVisible="{Binding IsLoading}" />
    </Grid>
</ContentPage>
