<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ForkFeedMobile.ViewModels"
             xmlns:models="clr-namespace:ForkFeedMobile.Models"
             xmlns:icons="clr-namespace:MauiIcons.FluentFilled;assembly=MauiIcons.FluentFilled"
             xmlns:controls="clr-namespace:ForkFeedMobile.Controls"
             x:Class="ForkFeedMobile.Views.FavoritesPage"
             x:DataType="vm:FavoritesViewModel"
             Title="Kedvencek"
             Shell.NavBarIsVisible="True"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource NavBarBackground}}">

    <Grid>
    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Error State -->
        <VerticalStackLayout Grid.Row="0"
                             IsVisible="{Binding HasError}"
                             Padding="16" Spacing="10"
                             HorizontalOptions="Center">
            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource ErrorRed}"
                   HorizontalTextAlignment="Center" />
            <Button Text="Újra"
                    Command="{Binding LoadFavoritesCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    HorizontalOptions="Center" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Favorites}"
                        SelectionMode="None">

            <CollectionView.Footer>
                <ContentView HeightRequest="100" />
            </CollectionView.Footer>

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Padding="40">
                    <icons:MauiIcon Icon="Heart28Filled" IconSize="48" IconColor="{StaticResource Gray400}" HorizontalOptions="Center" />
                    <Label Text="Nincsenek kedvenceid." FontSize="18"
                           TextColor="{StaticResource Gray400}"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Koppints a szívre egy recepten a mentéshez."
                           FontSize="14" TextColor="{StaticResource Gray300}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Recipe">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text=""
                                           IconImageSource="{icons:Icon Icon=Delete48Filled}"
                                           BackgroundColor="{StaticResource ErrorRed}"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FavoritesViewModel}}, Path=RemoveFavoriteCommand}"
                                           CommandParameter="{Binding}" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <!-- Recipe Card (same layout as HomePage) -->
                        <Frame Margin="16,8" Padding="0" CornerRadius="12" HasShadow="True" BorderColor="Transparent"
                               BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FavoritesViewModel}}, Path=GoToDetailCommand}"
                                    CommandParameter="{Binding}" />
                            </Frame.GestureRecognizers>

                            <Grid RowDefinitions="180,Auto">
                                <!-- Recipe Image -->
                                <Image Grid.Row="0"
                                       Source="{Binding ImageUrl}"
                                       Aspect="AspectFill"
                                       HeightRequest="180" />

                                <!-- Recipe Info -->
                                <VerticalStackLayout Grid.Row="1" Padding="12" Spacing="4">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0" Text="{Binding Title}"
                                               FontSize="18" FontAttributes="Bold"
                                               LineBreakMode="TailTruncation" />

                                        <!-- Favorite Heart (always filled on this page) -->
                                        <icons:MauiIcon Grid.Column="1"
                                               Icon="{Binding IsFavorite, Converter={StaticResource FavoriteIcon}}"
                                               IconColor="{Binding IsFavorite, Converter={StaticResource FavoriteColor}}"
                                               IconSize="24"
                                               VerticalOptions="Center">
                                            <icons:MauiIcon.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FavoritesViewModel}}, Path=RemoveFavoriteCommand}"
                                                    CommandParameter="{Binding}" />
                                            </icons:MauiIcon.GestureRecognizers>
                                        </icons:MauiIcon>
                                    </Grid>

                                    <HorizontalStackLayout Spacing="12">
                                        <Label Text="{Binding Difficulty}"
                                               FontSize="13"
                                               TextColor="{StaticResource Gray500}"
                                               Padding="6,2"
                                               BackgroundColor="{StaticResource Secondary}" />
                                        <HorizontalStackLayout Spacing="4">
                                            <icons:MauiIcon Icon="Timer24Filled" IconSize="13" IconColor="{StaticResource Gray500}" VerticalOptions="Center" />
                                            <Label FontSize="13" TextColor="{StaticResource Gray500}" VerticalOptions="Center">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding TimeMinutes}" />
                                                        <Span Text=" min" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout Spacing="4">
                                            <icons:MauiIcon Icon="Star12Filled" IconSize="13" IconColor="{StaticResource StarFilled}" VerticalOptions="Center" />
                                            <Label FontSize="13" TextColor="{StaticResource StarFilled}" VerticalOptions="Center">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding Rating, StringFormat='{0:F1}'}" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </HorizontalStackLayout>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Grid>
                        </Frame>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator Grid.Row="2"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="{StaticResource Primary}" Margin="0,8" />
    </Grid>
    <controls:FloatingNavBar />
    </Grid>
</ContentPage>
