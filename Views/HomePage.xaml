<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ForkFeedMobile.ViewModels"
             xmlns:models="clr-namespace:ForkFeedMobile.Models"
             xmlns:icons="clr-namespace:MauiIcons.FluentFilled;assembly=MauiIcons.FluentFilled"
             xmlns:controls="clr-namespace:ForkFeedMobile.Controls"
             x:Class="ForkFeedMobile.Views.HomePage"
             x:DataType="vm:HomeViewModel"
             Title="🍴 ForkFeed"
             Shell.NavBarIsVisible="True"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource NavBarBackground}}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="🌗" Clicked="OnThemeToggleClicked" Order="Primary" />
    </ContentPage.ToolbarItems>

    <Grid>
        <Grid RowDefinitions="Auto,Auto,*,Auto" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource NavBarBackground}}"
              IsVisible="{Binding IsNotLoading}">

        <!-- Search & Filter Bar -->
        <Border Grid.Row="0" Margin="16,12" Padding="6"
                StrokeShape="RoundRectangle 35"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource NavBarBackground}}">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="16" Opacity="{AppThemeBinding Light=0.1, Dark=0.4}" />
            </Border.Shadow>
            <Grid ColumnDefinitions="4*,*" ColumnSpacing="6">
                <!-- Search Input (pill) -->
                <Border Grid.Column="0"
                        StrokeShape="RoundRectangle 24"
                        StrokeThickness="0"
                        Padding="14,0"
                        HeightRequest="48"
                        BackgroundColor="{AppThemeBinding Light=#10000000, Dark=#15FFFFFF}">
                    <Grid ColumnDefinitions="Auto,*">
                        <Path Grid.Column="0"
                              Data="M15.5 14h-.79l-.28-.27A6.47 6.47 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                              Fill="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                              Aspect="Uniform" WidthRequest="20" HeightRequest="20"
                              VerticalOptions="Center" />
                        <Entry Grid.Column="1"
                               Placeholder="Keress rá valamire..."
                               Text="{Binding SearchText}"
                               FontSize="15"
                               Margin="10,0,0,0"
                               VerticalOptions="Center"
                               BackgroundColor="Transparent"
                               PlaceholderColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                               TextColor="{AppThemeBinding Light={StaticResource PrimaryTextColorLight}, Dark={StaticResource PrimaryTextColorDark}}" />
                    </Grid>
                </Border>

                <!-- Filter Button (pill) -->
                <Border Grid.Column="1"
                        StrokeShape="RoundRectangle 24"
                        StrokeThickness="0"
                        HeightRequest="48"
                        BackgroundColor="{StaticResource NavBarAccent}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFilterTapped" />
                    </Border.GestureRecognizers>
                    <Path Data="M10 18h4v-2h-4v2zM3 6v2h18V6H3zm3 7h12v-2H6v2z"
                          Fill="White"
                          Aspect="Uniform" WidthRequest="22" HeightRequest="22"
                          HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </Grid>
        </Border>

        <!-- Error State -->
        <VerticalStackLayout Grid.Row="1"
                             IsVisible="{Binding HasError}"
                             Padding="16" Spacing="10"
                             HorizontalOptions="Center">
            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource ErrorRed}"
                   HorizontalTextAlignment="Center" />
            <Button Text="Újra"
                    Command="{Binding RetryCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="{AppThemeBinding Light={StaticResource PrimaryTextColorDark}, Dark={StaticResource PrimaryTextColorDark}}"
                    HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Recipe List -->
        <RefreshView Grid.Row="2"
                     IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding LoadRecipesCommand}">
            <CollectionView ItemsSource="{Binding Recipes}"
                            RemainingItemsThreshold="2"
                            RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}"
                            SelectionMode="None"
                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource NavBarBackground}}">

                <CollectionView.Footer>
                    <ContentView HeightRequest="100" />
                </CollectionView.Footer>

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Padding="40">
                        <icons:MauiIcon Icon="Food24Filled" IconSize="48" HorizontalOptions="Center" IconColor="Gray"/>
                        <Label Text="Nem található recept." FontSize="18"
                               TextColor="{StaticResource Gray400}"
                               HorizontalTextAlignment="Center" />
                        <Label Text="Állíts a kereséseden vagy töltsd újra az oldalt." FontSize="18"
       TextColor="{StaticResource Gray400}"
       HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Recipe">
                            <Border Margin="16,8" Padding="0"
                                StrokeShape="RoundRectangle 16"
                                StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=GoToDetailCommand}"
                                    CommandParameter="{Binding}" />
                            </Border.GestureRecognizers>

                            <Grid RowDefinitions="180,Auto">
                                <!-- Recipe Image -->
                                <Image Grid.Row="0"
                                       Source="{Binding ImageUrl}"
                                       Aspect="AspectFill"
                                       HeightRequest="180">
                                    <Image.Clip>
                                        <RoundRectangleGeometry CornerRadius="16,16,0,0" Rect="0,0,400,180" />
                                    </Image.Clip>
                                </Image>

                                <!-- Recipe Info -->
                                <VerticalStackLayout Grid.Row="1" Padding="12" Spacing="4">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0" Text="{Binding Title}"
                                               FontSize="18" FontAttributes="Bold"
                                               LineBreakMode="TailTruncation" />

                                        <!-- Favorite Button -->
                                        <icons:MauiIcon Grid.Column="1"
                                               Icon="{Binding IsFavorite, Converter={StaticResource FavoriteIcon}}"
                                               IconColor="{Binding IsFavorite, Converter={StaticResource FavoriteColor}}"
                                               IconSize="24"
                                               VerticalOptions="Center">
                                            <icons:MauiIcon.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=ToggleFavoriteCommand}"
                                                    CommandParameter="{Binding}" />
                                            </icons:MauiIcon.GestureRecognizers>
                                        </icons:MauiIcon>
                                    </Grid>

                                    <HorizontalStackLayout Spacing="12">
                                        <Border StrokeShape="RoundRectangle 12"
                                                Stroke="{Binding DifficultyBorderColor}"
                                                BackgroundColor="{Binding DifficultyBackgroundColor}"
                                                Padding="10,4"
                                                StrokeThickness="1.5"
                                                VerticalOptions="Center">
                                            <Label Text="{Binding DifficultyDisplay}"
                                                   FontSize="12"
                                                   FontAttributes="Bold"
                                                   TextColor="White" />
                                        </Border>
                                        <HorizontalStackLayout Spacing="4">
                                            <icons:MauiIcon Icon="Timer24Filled" IconSize="13" IconColor="{StaticResource Gray500}" VerticalOptions="Center" />
                                            <Label FontSize="13" TextColor="{StaticResource Gray500}" VerticalOptions="Center">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding TimeMinutes}" />
                                                        <Span Text=" min" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout Spacing="4">
                                            <icons:MauiIcon Icon="Star12Filled" IconSize="13" IconColor="{StaticResource StarFilled}" VerticalOptions="Center" />
                                            <Label FontSize="13" TextColor="{StaticResource StarFilled}" VerticalOptions="Center">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding Rating, StringFormat='{0:F1}'}" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </HorizontalStackLayout>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

    </Grid>
    <!-- Centered Loading Overlay -->
    <controls:LoadingOverlay IsVisible="{Binding IsLoading}" />
    <controls:FloatingNavBar />
    </Grid>
</ContentPage>
