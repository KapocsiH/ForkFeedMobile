<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="ForkFeedMobile.Views.DeactivateAccountPopup"
               CanBeDismissedByTappingOutsideOfPopup="False"
               Color="Transparent">

    <Border StrokeShape="RoundRectangle 16"
            StrokeThickness="0"
            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource CardDark}}"
            Padding="24"
            WidthRequest="320">
        <Border.Shadow>
            <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.3" />
        </Border.Shadow>

        <VerticalStackLayout Spacing="16">

            <!-- Warning Icon -->
            <Label Text="??"
                   FontSize="36"
                   HorizontalTextAlignment="Center" />

            <!-- Title -->
            <Label Text="Fiók deaktiválása"
                   FontSize="20"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />

            <!-- Warning Message -->
            <Label Text="A fiókod deaktiválása után nem tudsz bejelentkezni. Ez a művelet visszafordítható egy admin által."
                   FontSize="14"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="WordWrap" />

            <!-- Password Entry -->
            <Entry x:Name="PasswordEntry"
                   Placeholder="A megerősítéshez add meg a jelszavad:"
                   IsPassword="True"
                   ReturnType="Done" />

            <!-- Error Label -->
            <Label x:Name="ErrorLabel"
                   TextColor="{StaticResource ErrorRed}"
                   FontSize="13"
                   HorizontalTextAlignment="Center"
                   IsVisible="False" />

            <!-- Loading Indicator -->
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="False"
                               IsVisible="False"
                               Color="{StaticResource Primary}" />

            <!-- Confirm Button -->
            <Button x:Name="ConfirmButton"
                    Text="Megerősítés"
                    BackgroundColor="{StaticResource ErrorRed}"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="48"
                    FontSize="16"
                    FontAttributes="Bold"
                    Clicked="OnConfirmClicked" />

            <!-- Cancel Button -->
            <Button Text="Mégsem"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"
                    FontSize="14"
                    Padding="0"
                    HeightRequest="40"
                    Clicked="OnCancelClicked" />

        </VerticalStackLayout>
    </Border>
</toolkit:Popup>
