<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ForkFeedMobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:ForkFeedMobile.Views"
    Shell.FlyoutBehavior="Disabled"
    Shell.TabBarBackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource DarkBackground}}"
    Shell.TabBarTitleColor="{StaticResource Primary}"
    Shell.TabBarUnselectedColor="{StaticResource Gray400}"
    Title="ForkFeed">

    <TabBar>
        <ShellContent Title="Home" Icon="icon_home"
                      ContentTemplate="{DataTemplate views:HomePage}"
                      Route="Home" />
        <ShellContent Title="Favorites" Icon="icon_heart"
                      ContentTemplate="{DataTemplate views:FavoritesPage}"
                      Route="Favorites" />
        <ShellContent Title="Add" Icon="icon_add"
                      ContentTemplate="{DataTemplate views:AddRecipePage}"
                      Route="AddRecipe" />
        <ShellContent Title="Profile" Icon="icon_profile"
                      ContentTemplate="{DataTemplate views:ProfilePage}"
                      Route="Profile" />
    </TabBar>

</Shell>
