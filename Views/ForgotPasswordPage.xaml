<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ForkFeedMobile.ViewModels"
             xmlns:icons="clr-namespace:MauiIcons.FluentFilled;assembly=MauiIcons.FluentFilled"
             x:Class="ForkFeedMobile.Views.ForgotPasswordPage"
             x:DataType="vm:ForgotPasswordViewModel"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="True">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="14">

            <icons:MauiIcon Icon="LockClosed24Filled" IconSize="60" HorizontalOptions="Center" Margin="0,20,0,0" />
            <Label Text="Reset Your Password"
                   FontSize="24" FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />

            <!-- Step 1: Request reset link -->
            <VerticalStackLayout IsVisible="{Binding ShowResetForm, Converter={StaticResource InvertBool}}"
                                 Spacing="14">
                <Label Text="Enter your email address and we'll send you a reset link."
                       FontSize="14" TextColor="{StaticResource Gray400}"
                       HorizontalTextAlignment="Center" Margin="0,0,0,8" />

                <Entry Placeholder="Email" Text="{Binding Email}" Keyboard="Email" />

                <Label Text="{Binding FormError}"
                       TextColor="{StaticResource ErrorRed}"
                       FontSize="13"
                       IsVisible="{Binding FormError, Converter={StaticResource StringNotEmpty}}"
                       HorizontalTextAlignment="Center" />

                <Button Text="Send Reset Link"
                        Command="{Binding SendResetLinkCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        CornerRadius="12" HeightRequest="50"
                        FontSize="18" FontAttributes="Bold" />
            </VerticalStackLayout>

            <!-- Step 2: Enter token and new password -->
            <VerticalStackLayout IsVisible="{Binding ShowResetForm}" Spacing="14">

                <Label Text="{Binding SuccessMessage}"
                       TextColor="{StaticResource SuccessGreen}"
                       FontSize="13"
                       IsVisible="{Binding SuccessMessage, Converter={StaticResource StringNotEmpty}}"
                       HorizontalTextAlignment="Center" />

                <Label Text="Enter the reset token from your email and choose a new password."
                       FontSize="14" TextColor="{StaticResource Gray400}"
                       HorizontalTextAlignment="Center" Margin="0,0,0,8" />

                <Entry Placeholder="Reset Token" Text="{Binding ResetToken}" />
                <Entry Placeholder="New Password" Text="{Binding NewPassword}" IsPassword="True" />
                <Entry Placeholder="Confirm New Password" Text="{Binding ConfirmNewPassword}" IsPassword="True" />

                <Label Text="{Binding FormError}"
                       TextColor="{StaticResource ErrorRed}"
                       FontSize="13"
                       IsVisible="{Binding FormError, Converter={StaticResource StringNotEmpty}}"
                       HorizontalTextAlignment="Center" />

                <Button Text="Reset Password"
                        Command="{Binding ResetPasswordCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        CornerRadius="12" HeightRequest="50"
                        FontSize="18" FontAttributes="Bold" />
            </VerticalStackLayout>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Primary}" />

            <Button Text="Back to Login"
                    Command="{Binding GoBackCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Primary}"
                    FontSize="14"
                    Padding="0"
                    HeightRequest="40" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
