<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ForkFeedMobile.ViewModels"
             xmlns:icons="clr-namespace:MauiIcons.FluentFilled;assembly=MauiIcons.FluentFilled"
             xmlns:controls="clr-namespace:ForkFeedMobile.Controls"
             x:Class="ForkFeedMobile.Views.EditProfilePage"
             x:DataType="vm:EditProfileViewModel"
             Title="Profil szerkesztése"
             Shell.NavBarIsVisible="True"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource NavBarBackground}}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <!-- Profile Image -->
            <Grid WidthRequest="120" HeightRequest="120"
                  HorizontalOptions="Center"
                  Margin="0,12,0,0">

                <!-- Placeholder avatar when no image is set -->
                <controls:AvatarView ImageUrl=""
                                     UserName="{Binding Username}"
                                     Size="120"
                                     IsVisible="{Binding HasAvatarImage, Converter={StaticResource InvertBool}}" />

                <!-- Real image -->
                <Border StrokeShape="RoundRectangle 60"
                        StrokeThickness="0"
                        IsVisible="{Binding HasAvatarImage}"
                        WidthRequest="120" HeightRequest="120">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.25" />
                    </Border.Shadow>
                    <Image Source="{Binding AvatarImageSource}"
                           Aspect="AspectFill"
                           WidthRequest="120"
                           HeightRequest="120" />
                </Border>
            </Grid>

            <!-- Image Action Buttons -->
            <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                <Button Text="Galéria"
                        Command="{Binding PickImageCommand}"
                        BackgroundColor="{StaticResource Secondary}"
                        TextColor="{StaticResource Primary}"
                        FontSize="13"
                        CornerRadius="8"
                        HeightRequest="38"
                        Padding="12,0" />
                <Button Text="Kamera"
                        Command="{Binding TakePhotoCommand}"
                        BackgroundColor="{StaticResource Secondary}"
                        TextColor="{StaticResource Primary}"
                        FontSize="13"
                        CornerRadius="8"
                        HeightRequest="38"
                        Padding="12,0" />
            </HorizontalStackLayout>

            <!-- Username -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Felhasználónév"
                       FontSize="14" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                <Entry Placeholder="Enter username"
                       Text="{Binding Username}" />
            </VerticalStackLayout>

            <!-- Bio -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Bio"
                       FontSize="14" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                <Editor Placeholder="Írj magadról valamit..."
                        Text="{Binding Bio}"
                        HeightRequest="80"
                        AutoSize="TextChanges" />
            </VerticalStackLayout>

            <!-- Error Message -->
            <Label Text="{Binding FormError}"
                   TextColor="{StaticResource ErrorRed}"
                   FontSize="13"
                   IsVisible="{Binding FormError, Converter={StaticResource StringNotEmpty}}"
                   HorizontalTextAlignment="Center" />

            <!-- Save Button -->
            <Button Text="Mentés"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="50"
                    FontSize="18" FontAttributes="Bold" />

            <!-- Cancel Button -->
            <Button Text="Mégsem"
                    Command="{Binding CancelCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource ErrorRed}"
                    FontSize="14"
                    Padding="0"
                    HeightRequest="20" />

            <!-- Loading Indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Primary}" />

            <!-- Separator -->
            <BoxView HeightRequest="1"
                     HorizontalOptions="Fill"
                     Color="{StaticResource Gray200}"
                     Margin="0,0,0,0" />

            <!-- Deactivate Profile -->
            <Button Text="Fiók deaktiválása"
                    Command="{Binding DeactivateAccountCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource ErrorRed}"
                    FontSize="14"
                    FontAttributes="Bold"
                    BorderColor="{StaticResource ErrorRed}"
                    BorderWidth="1.5"
                    CornerRadius="12"
                    HeightRequest="48"
                    Margin="0,0,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
