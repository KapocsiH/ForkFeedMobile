<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ForkFeedMobile.ViewModels"
             x:Class="ForkFeedMobile.Views.ShoppingListPage"
             x:DataType="vm:ShoppingListViewModel"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="True">

    <VerticalStackLayout Padding="24" Spacing="16" VerticalOptions="Center">
        <Label Text="Shopping List"
               FontSize="24" FontAttributes="Bold"
               HorizontalTextAlignment="Center" />
        <Label Text="Your shopping list will appear here."
               FontSize="16" TextColor="{StaticResource Gray400}"
               HorizontalTextAlignment="Center" />
    </VerticalStackLayout>

</ContentPage>
