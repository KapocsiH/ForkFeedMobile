<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ForkFeedMobile.ViewModels"
             xmlns:models="clr-namespace:ForkFeedMobile.Models"
             x:Class="ForkFeedMobile.Views.HomePage"
             x:DataType="vm:HomeViewModel"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="True">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Search & Filter Bar -->
        <VerticalStackLayout Grid.Row="0" Padding="16,12" Spacing="10"
                             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource DarkBackground}}">

            <SearchBar Placeholder="Search recipes..."
                       Text="{Binding SearchText}"
                       CancelButtonColor="{StaticResource Primary}" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Picker Grid.Column="0"
                        Title="Difficulty"
                        ItemsSource="{Binding DifficultyOptions}"
                        SelectedItem="{Binding SelectedDifficulty}" />
                <Picker Grid.Column="1"
                        Title="Sort by"
                        ItemsSource="{Binding SortOptions}"
                        SelectedItem="{Binding SelectedSort}" />
            </Grid>
        </VerticalStackLayout>

        <!-- Error State -->
        <VerticalStackLayout Grid.Row="1"
                             IsVisible="{Binding HasError}"
                             Padding="16" Spacing="10"
                             HorizontalOptions="Center">
            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource ErrorRed}"
                   HorizontalTextAlignment="Center" />
            <Button Text="Retry"
                    Command="{Binding RetryCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Recipe List -->
        <RefreshView Grid.Row="2"
                     IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding LoadRecipesCommand}">
            <CollectionView ItemsSource="{Binding Recipes}"
                            RemainingItemsThreshold="2"
                            RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}"
                            SelectionMode="None">

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Padding="40">
                        <Label Text="???" FontSize="48" HorizontalTextAlignment="Center" />
                        <Label Text="No recipes found" FontSize="18"
                               TextColor="{StaticResource Gray400}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Recipe">
                        <Frame Margin="16,8" Padding="0" CornerRadius="12" HasShadow="True" BorderColor="Transparent"
                               BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=GoToDetailCommand}"
                                    CommandParameter="{Binding}" />
                            </Frame.GestureRecognizers>

                            <Grid RowDefinitions="180,Auto">
                                <!-- Recipe Image -->
                                <Image Grid.Row="0"
                                       Source="{Binding ImageUrl}"
                                       Aspect="AspectFill"
                                       HeightRequest="180" />

                                <!-- Recipe Info -->
                                <VerticalStackLayout Grid.Row="1" Padding="12" Spacing="4">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0" Text="{Binding Title}"
                                               FontSize="18" FontAttributes="Bold"
                                               LineBreakMode="TailTruncation" />

                                        <!-- Favorite Button -->
                                        <Label Grid.Column="1"
                                               Text="{Binding IsFavorite, Converter={StaticResource FavoriteIcon}}"
                                               FontSize="24"
                                               VerticalOptions="Center">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=ToggleFavoriteCommand}"
                                                    CommandParameter="{Binding}" />
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </Grid>

                                    <HorizontalStackLayout Spacing="12">
                                        <Label Text="{Binding Difficulty}"
                                               FontSize="13"
                                               TextColor="{StaticResource Gray500}"
                                               Padding="6,2"
                                               BackgroundColor="{StaticResource Secondary}" />
                                        <Label FontSize="13" TextColor="{StaticResource Gray500}">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="? " />
                                                    <Span Text="{Binding TimeMinutes}" />
                                                    <Span Text=" min" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                        <Label FontSize="13" TextColor="{StaticResource StarFilled}">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="? " />
                                                    <Span Text="{Binding Rating, StringFormat='{0:F1}'}" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Loading Indicator -->
        <ActivityIndicator Grid.Row="3"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="{StaticResource Primary}"
                           Margin="0,8" />
    </Grid>
</ContentPage>
