<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ForkFeedMobile.ViewModels"
             xmlns:models="clr-namespace:ForkFeedMobile.Models"
             xmlns:icons="clr-namespace:MauiIcons.FluentFilled;assembly=MauiIcons.FluentFilled"
             xmlns:controls="clr-namespace:ForkFeedMobile.Controls"
             x:Class="ForkFeedMobile.Views.ProfilePage"
             x:DataType="vm:ProfileViewModel"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="True">

    <Grid>
        <!-- Main scrollable content -->
        <ScrollView>
            <VerticalStackLayout Padding="24,8,24,80" Spacing="12">

                <!-- Loading Indicator -->
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="{StaticResource Primary}"
                                   HorizontalOptions="Center"
                                   Margin="0,12,0,0" />

                <!-- Logged-In View -->
                <VerticalStackLayout IsVisible="{Binding IsLoggedIn}" Spacing="12">

                    <!-- Profile Header (Instagram-like) -->
                    <Grid x:Name="ProfileHeader"
                          ColumnDefinitions="Auto,*"
                          ColumnSpacing="20"
                          Padding="8,0,8,0"
                          Opacity="0">

                        <!-- Circular Profile Image -->
                        <controls:AvatarView Grid.Column="0"
                                             ImageUrl="{Binding User.AvatarUrl}"
                                             UserName="{Binding User.DisplayName}"
                                             Size="100"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center" />

                        <!-- Username + Stats -->
                        <VerticalStackLayout Grid.Column="1"
                                             VerticalOptions="Center"
                                             Spacing="8">

                            <!-- Display Name -->
                            <Label Text="{Binding User.DisplayName}"
                                   FontSize="20" FontAttributes="Bold"
                                   HorizontalTextAlignment="Center" />

                            <!-- Stats Row: Rating | Recipes | Collections -->
                            <Grid ColumnDefinitions="*,*,*"
                                  HorizontalOptions="Fill">

                                <!-- Average Rating -->
                                <VerticalStackLayout Grid.Column="0" Spacing="2" HorizontalOptions="Center">
                                    <Label Text="{Binding AverageRating, StringFormat='{0:F1}'}"
                                           FontSize="22" FontAttributes="Bold"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="Rating"
                                           FontSize="12"
                                           TextColor="{StaticResource Gray400}"
                                           HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>

                                <!-- Recipe Count -->
                                <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="Center">
                                    <Label Text="{Binding RecipeCount}"
                                           FontSize="22" FontAttributes="Bold"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="Recipes"
                                           FontSize="12"
                                           TextColor="{StaticResource Gray400}"
                                           HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>

                                <!-- Collection Count -->
                                <VerticalStackLayout Grid.Column="2" Spacing="2" HorizontalOptions="Center">
                                    <Label Text="{Binding CollectionCount}"
                                           FontSize="22" FontAttributes="Bold"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="Books"
                                           FontSize="12"
                                           TextColor="{StaticResource Gray400}"
                                           HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Bio Section -->
                    <VerticalStackLayout IsVisible="{Binding HasBio}"
                                         Spacing="4"
                                         Padding="8,4,8,0">
                        <Label Text="{Binding Bio}"
                               FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"
                               LineBreakMode="TailTruncation"
                               MaxLines="{Binding BioMaxLines}"
                               HorizontalTextAlignment="Start" />
                        <Label Text="{Binding IsBioExpanded, StringFormat='{0:More;;Less}'}"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Primary}"
                               HorizontalTextAlignment="Start">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding IsBioExpanded}"
                                             Value="False">
                                    <Setter Property="Text" Value="More" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding IsBioExpanded}"
                                             Value="True">
                                    <Setter Property="Text" Value="Less" />
                                </DataTrigger>
                            </Label.Triggers>
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleBioCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </VerticalStackLayout>

                    <!-- Error Message -->
                    <Label Text="{Binding ErrorMessage}"
                           TextColor="{StaticResource ErrorRed}"
                           FontSize="13"
                           IsVisible="{Binding HasError}"
                           HorizontalTextAlignment="Center" />

                    <!-- Tab Switcher -->
                    <Grid ColumnDefinitions="*,*,*"
                          Margin="0,8,0,0">

                        <!-- Recipes Tab -->
                        <VerticalStackLayout Grid.Column="0"
                                             Spacing="6"
                                             HorizontalOptions="Fill">
                            <Label Text="Recipes"
                                   FontSize="15"
                                   HorizontalTextAlignment="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding IsRecipesTabSelected}"
                                                 Value="True">
                                        <Setter Property="FontAttributes" Value="Bold" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <BoxView HeightRequest="2"
                                     HorizontalOptions="Fill"
                                     Color="{StaticResource Primary}"
                                     IsVisible="{Binding IsRecipesTabSelected}" />
                            <VerticalStackLayout.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectTabCommand}"
                                                      CommandParameter="Recipes" />
                            </VerticalStackLayout.GestureRecognizers>
                        </VerticalStackLayout>

                        <!-- Books Tab -->
                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="6"
                                             HorizontalOptions="Fill">
                            <Label Text="Books"
                                   FontSize="15"
                                   HorizontalTextAlignment="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding IsBooksTabSelected}"
                                                 Value="True">
                                        <Setter Property="FontAttributes" Value="Bold" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <BoxView HeightRequest="2"
                                     HorizontalOptions="Fill"
                                     Color="{StaticResource Primary}"
                                     IsVisible="{Binding IsBooksTabSelected}" />
                            <VerticalStackLayout.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectTabCommand}"
                                                      CommandParameter="Books" />
                            </VerticalStackLayout.GestureRecognizers>
                        </VerticalStackLayout>

                        <!-- Comments Tab -->
                        <VerticalStackLayout Grid.Column="2"
                                             Spacing="6"
                                             HorizontalOptions="Fill">
                            <Label Text="Comments"
                                   FontSize="15"
                                   HorizontalTextAlignment="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding IsCommentsTabSelected}"
                                                 Value="True">
                                        <Setter Property="FontAttributes" Value="Bold" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <BoxView HeightRequest="2"
                                     HorizontalOptions="Fill"
                                     Color="{StaticResource Primary}"
                                     IsVisible="{Binding IsCommentsTabSelected}" />
                            <VerticalStackLayout.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectTabCommand}"
                                                      CommandParameter="Comments" />
                            </VerticalStackLayout.GestureRecognizers>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Divider -->
                    <BoxView HeightRequest="1"
                             HorizontalOptions="Fill"
                             Color="{StaticResource Gray200}"
                             Margin="0,-4,0,0" />

                    <!-- Recipes Tab Content -->
                    <CollectionView ItemsSource="{Binding UserRecipes}"
                                    IsVisible="{Binding IsRecipesTabSelected}"
                                    SelectionMode="None">

                        <CollectionView.EmptyView>
                            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Padding="40">
                                <icons:MauiIcon Icon="Food24Filled" IconSize="48" HorizontalOptions="Center" />
                                <Label Text="No recipes yet" FontSize="18"
                                       TextColor="{StaticResource Gray400}"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Recipe">
                                <Frame Margin="0,8" Padding="0" CornerRadius="12" HasShadow="True" BorderColor="Transparent"
                                       BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ProfileViewModel}}, Path=GoToRecipeDetailCommand}"
                                            CommandParameter="{Binding}" />
                                    </Frame.GestureRecognizers>

                                    <Grid>
                                        <VerticalStackLayout Padding="12" Spacing="4">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <Label Grid.Column="0" Text="{Binding Title}"
                                                       FontSize="18" FontAttributes="Bold"
                                                       LineBreakMode="TailTruncation" />

                                                <icons:MauiIcon Grid.Column="1"
                                                       Icon="{Binding IsFavorite, Converter={StaticResource FavoriteIcon}}"
                                                       IconColor="{Binding IsFavorite, Converter={StaticResource FavoriteColor}}"
                                                       IconSize="24"
                                                       VerticalOptions="Center">
                                                    <icons:MauiIcon.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ProfileViewModel}}, Path=ToggleUserRecipeFavoriteCommand}"
                                                            CommandParameter="{Binding}" />
                                                    </icons:MauiIcon.GestureRecognizers>
                                                </icons:MauiIcon>
                                            </Grid>

                                            <HorizontalStackLayout Spacing="12">
                                                <Label Text="{Binding Difficulty}"
                                                       FontSize="13"
                                                       TextColor="{StaticResource Gray500}"
                                                       Padding="6,2"
                                                       BackgroundColor="{StaticResource Secondary}" />
                                                <HorizontalStackLayout Spacing="4">
                                                    <icons:MauiIcon Icon="Timer24Filled" IconSize="13" IconColor="{StaticResource Gray500}" VerticalOptions="Center" />
                                                    <Label FontSize="13" TextColor="{StaticResource Gray500}" VerticalOptions="Center">
                                                        <Label.FormattedText>
                                                            <FormattedString>
                                                                <Span Text="{Binding TimeMinutes}" />
                                                                <Span Text=" min" />
                                                            </FormattedString>
                                                        </Label.FormattedText>
                                                    </Label>
                                                </HorizontalStackLayout>
                                                <HorizontalStackLayout Spacing="4">
                                                    <icons:MauiIcon Icon="Star12Filled" IconSize="13" IconColor="{StaticResource StarFilled}" VerticalOptions="Center" />
                                                    <Label FontSize="13" TextColor="{StaticResource StarFilled}" VerticalOptions="Center">
                                                        <Label.FormattedText>
                                                            <FormattedString>
                                                                <Span Text="{Binding Rating, StringFormat='{0:F1}'}" />
                                                            </FormattedString>
                                                        </Label.FormattedText>
                                                    </Label>
                                                </HorizontalStackLayout>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Label Text="Books coming soon"
                           IsVisible="{Binding IsBooksTabSelected}"
                           FontSize="16"
                           TextColor="{StaticResource Gray400}"
                           Opacity="0.6"
                           HorizontalTextAlignment="Center"
                           HorizontalOptions="Center"
                           Margin="0,32,0,0" />

                    <!-- Comments Tab Content -->
                    <CollectionView ItemsSource="{Binding UserComments}"
                                    IsVisible="{Binding IsCommentsTabSelected}"
                                    SelectionMode="None">

                        <CollectionView.EmptyView>
                            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Padding="40">
                                <icons:MauiIcon Icon="ChatEmpty24Filled" IconSize="48" HorizontalOptions="Center" />
                                <Label Text="No comments yet" FontSize="18"
                                       TextColor="{StaticResource Gray400}"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:UserComment">
                                <Frame Margin="0,8" Padding="0" CornerRadius="12" HasShadow="True" BorderColor="Transparent"
                                       BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ProfileViewModel}}, Path=GoToCommentRecipeDetailCommand}"
                                            CommandParameter="{Binding}" />
                                    </Frame.GestureRecognizers>

                                    <VerticalStackLayout Padding="12" Spacing="6">
                                        <!-- Recipe Title -->
                                        <Label Text="{Binding RecipeTitle}"
                                               FontSize="18" FontAttributes="Bold"
                                               LineBreakMode="TailTruncation" />

                                        <!-- Recipe Author Row -->
                                        <HorizontalStackLayout Spacing="8"
                                                               VerticalOptions="Center">
                                            <controls:AvatarView ImageUrl="{Binding RecipeAuthorProfileImageUrl}"
                                                                  UserName="{Binding RecipeAuthorUsername}"
                                                                  Size="28" />
                                            <Label Text="{Binding RecipeAuthorUsername}"
                                                   FontSize="14"
                                                   TextColor="{StaticResource Gray500}"
                                                   VerticalOptions="Center" />
                                        </HorizontalStackLayout>

                                        <!-- Comment Text -->
                                        <Label Text="{Binding CommentText}"
                                               FontSize="14"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="3" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Login View -->
                <VerticalStackLayout IsVisible="{Binding IsOwnProfile}" Spacing="14">
                    <VerticalStackLayout IsVisible="{Binding IsLoggedIn, Converter={StaticResource InvertBool}}" Spacing="14">

                    <icons:MauiIcon Icon="Food24Filled" IconSize="60" HorizontalOptions="Center" Margin="0,20,0,0" />
                    <Label Text="Welcome to ForkFeed"
                           FontSize="24" FontAttributes="Bold"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Sign in to save your recipes and favorites"
                           FontSize="14" TextColor="{StaticResource Gray400}"
                           HorizontalTextAlignment="Center" />

                    <Entry Placeholder="Email or Username" Text="{Binding Email}"
                           Keyboard="Email" Margin="0,12,0,0" />
                    <Entry Placeholder="Password" Text="{Binding Password}"
                           IsPassword="True" />

                    <Label Text="{Binding LoginError}"
                           TextColor="{StaticResource ErrorRed}"
                           FontSize="13"
                           IsVisible="{Binding LoginError, Converter={StaticResource StringNotEmpty}}"
                           HorizontalTextAlignment="Center" />

                    <Button Text="Login"
                            Command="{Binding LoginCommand}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            CornerRadius="12" HeightRequest="50"
                            FontSize="18" FontAttributes="Bold" />

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="{StaticResource Primary}" />

                    <!-- Forgot Password -->
                    <Button Text="I forgot my password"
                            Command="{Binding GoToForgotPasswordCommand}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource Primary}"
                            FontSize="14"
                            Padding="0"
                            HeightRequest="40" />

                    <!-- Register -->
                    <Button Text="I don't have an account"
                            Command="{Binding GoToRegisterCommand}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource Accent}"
                            FontSize="14" FontAttributes="Bold"
                            Padding="0"
                            HeightRequest="40" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Action buttons pinned to bottom-right -->
        <VerticalStackLayout IsVisible="{Binding IsOwnProfile}"
                             Spacing="12"
                             HorizontalOptions="End"
                             VerticalOptions="End"
                             Margin="0,0,20,20">

            <!-- Only show when logged in -->
            <VerticalStackLayout IsVisible="{Binding IsLoggedIn}"
                                 Spacing="12"
                                 HorizontalOptions="End">

            <!-- Settings button -->
            <Border BackgroundColor="White"
                    StrokeShape="RoundRectangle 14"
                    StrokeThickness="0"
                    WidthRequest="48"
                    HeightRequest="48"
                    HorizontalOptions="End">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.3" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToEditProfileCommand}" />
                </Border.GestureRecognizers>
                <icons:MauiIcon Icon="Options24Filled"
                       IconSize="22"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>

            <!-- Logout button -->
            <Border BackgroundColor="{StaticResource ErrorRed}"
                    StrokeShape="RoundRectangle 14"
                    StrokeThickness="0"
                    WidthRequest="48"
                    HeightRequest="48"
                    HorizontalOptions="End">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.3" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding LogoutCommand}" />
                </Border.GestureRecognizers>
                <icons:MauiIcon Icon="SignOut24Filled"
                       IconSize="22"
                       IconColor="White"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
