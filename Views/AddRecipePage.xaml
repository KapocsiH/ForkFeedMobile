<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ForkFeedMobile.ViewModels"
             xmlns:models="clr-namespace:ForkFeedMobile.Models"
             xmlns:icons="clr-namespace:MauiIcons.FluentFilled;assembly=MauiIcons.FluentFilled"
             xmlns:controls="clr-namespace:ForkFeedMobile.Controls"
             x:Class="ForkFeedMobile.Views.AddRecipePage"
             x:DataType="vm:AddRecipeViewModel"
             Title="Új recept"
             Shell.NavBarIsVisible="True"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource NavBarBackground}}">

    <Grid>
    <ScrollView>
        <VerticalStackLayout Padding="16,16,16,100" Spacing="12">

            <!-- Image Picker -->
            <Frame CornerRadius="12" Padding="0" HeightRequest="200"
                   BackgroundColor="{StaticResource Gray100}" BorderColor="Transparent"
                   HasShadow="False">
                <Grid>
                    <Image Source="{Binding SelectedImageSource}"
                           Aspect="AspectFill"
                           IsVisible="{Binding SelectedImageSource, Converter={StaticResource NotNull}}" />
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                        <icons:MauiIcon Icon="ImageAdd24Filled" IconSize="40" HorizontalOptions="Center" />
                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Button Text="Galéria" Command="{Binding PickImageCommand}"
                                    BackgroundColor="{StaticResource Primary}" TextColor="White"
                                    CornerRadius="8" FontSize="13" HeightRequest="36" />
                            <Button Text="Kamera" Command="{Binding TakePhotoCommand}"
                                    BackgroundColor="{StaticResource Accent}" TextColor="White"
                                    CornerRadius="8" FontSize="13" HeightRequest="36" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Grid>
            </Frame>

            <!-- Title -->
            <Label Text="Recept neve" FontSize="14" FontAttributes="Bold" />
            <Entry Placeholder="pl. Nagymama almás pitéje"
                   Text="{Binding RecipeTitle}" />

            <!-- Description -->
            <Label Text="Leírás" FontSize="14" FontAttributes="Bold" />
            <Editor Placeholder="Írj röviden a receptről..."
                    Text="{Binding Description}"
                    HeightRequest="80"
                    AutoSize="TextChanges" />

            <!-- Difficulty -->
            <Label Text="Nehézség" FontSize="14" FontAttributes="Bold" />
            <Picker ItemsSource="{Binding DifficultyOptions}"
                    SelectedItem="{Binding SelectedDifficulty}" />

            <!-- Cooking Time -->
            <Label Text="Elkészítési idő (perc)" FontSize="14" FontAttributes="Bold" />
            <Entry Placeholder="pl. 30"
                   Text="{Binding CookingTimeMinutes}"
                   Keyboard="Numeric" />

            <!-- Category -->
            <Label Text="Kategóriák" FontSize="14" FontAttributes="Bold" />
            <Picker ItemsSource="{Binding CategoryOptions}"
                    SelectedItem="{Binding SelectedCategory}" />

            <!-- Tags -->
            <Label Text="Címkék" FontSize="18" FontAttributes="Bold" Margin="0,8,0,0" />
            <FlexLayout BindableLayout.ItemsSource="{Binding AvailableTags}"
                        Wrap="Wrap" Direction="Row"
                        AlignItems="Center" JustifyContent="Start">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:SelectableTag">
                        <Border Padding="10,6" Margin="4" StrokeShape="RoundRectangle 12"
                                Stroke="{StaticResource Primary}"
                                BackgroundColor="{Binding IsSelected, Converter={StaticResource TagBackgroundConverter}}"
                                StrokeThickness="1">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AddRecipeViewModel}}, Path=ToggleTagCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Label Text="{Binding Name}" FontSize="14"
                                   TextColor="{Binding IsSelected, Converter={StaticResource TagTextColorConverter}}"
                                   VerticalOptions="Center" />
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>

            <!-- Ingredients -->
            <Label Text="Hozzávalók" FontSize="18" FontAttributes="Bold" Margin="0,8,0,0" />
            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                <Entry Grid.Column="0" Placeholder="Hozzávaló neve"
                       Text="{Binding NewIngredientName}" />
                <Entry Grid.Column="1" Placeholder="Menny." WidthRequest="70"
                       Text="{Binding NewIngredientQty}"
                       Keyboard="Numeric" />
                <Entry Grid.Column="2" Placeholder="M.e." WidthRequest="60"
                       Text="{Binding NewIngredientUnit}" />
                <Button Grid.Column="3" Text="+" WidthRequest="44" HeightRequest="44"
                        Command="{Binding AddIngredientCommand}"
                        BackgroundColor="{StaticResource Primary}" TextColor="White"
                        CornerRadius="22" FontSize="20" Padding="0" />
            </Grid>

            <CollectionView ItemsSource="{Binding Ingredients}" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Ingredient">
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="Törlés"
                                               BackgroundColor="{StaticResource ErrorRed}"
                                               Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AddRecipeViewModel}}, Path=RemoveIngredientCommand}"
                                               CommandParameter="{Binding}" />
                                </SwipeItems>
                            </SwipeView.RightItems>
                            <Grid ColumnDefinitions="*,Auto" Padding="8,4" BackgroundColor="Transparent">
                                <Label Grid.Column="0" Text="{Binding Name}" FontSize="15" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding DisplayQuantity}" FontSize="14"
                                       TextColor="{StaticResource Gray400}" VerticalOptions="Center" />
                            </Grid>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Steps -->
            <Label Text="Elkészítés lépései" FontSize="18" FontAttributes="Bold" Margin="0,8,0,0" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Entry Grid.Column="0" Placeholder="Írd le a lépést..."
                       Text="{Binding NewStepDescription}" />
                <Button Grid.Column="1" Text="+" WidthRequest="44" HeightRequest="44"
                        Command="{Binding AddStepCommand}"
                        BackgroundColor="{StaticResource Primary}" TextColor="White"
                        CornerRadius="22" FontSize="20" Padding="0" />
            </Grid>

            <CollectionView ItemsSource="{Binding Steps}" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:RecipeStep">
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="Törlés"
                                               BackgroundColor="{StaticResource ErrorRed}"
                                               Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AddRecipeViewModel}}, Path=RemoveStepCommand}"
                                               CommandParameter="{Binding}" />
                                </SwipeItems>
                            </SwipeView.RightItems>
                            <HorizontalStackLayout Spacing="8" Padding="8,4" BackgroundColor="Transparent">
                                <Label Text="{Binding StepNumber, StringFormat='{0}.'}"
                                       FontAttributes="Bold" FontSize="15" VerticalOptions="Center"
                                       TextColor="{StaticResource Primary}" />
                                <Label Text="{Binding Description}" FontSize="15" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Save Button -->
            <Button Text="Feltöltés"
                    Command="{Binding SaveRecipeCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    FontSize="18" FontAttributes="Bold"
                    CornerRadius="12"
                    HeightRequest="56"
                    Margin="0,16,0,24"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Primary}" />
        </VerticalStackLayout>
    </ScrollView>
    <controls:FloatingNavBar />
    </Grid>
</ContentPage>
