<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ForkFeedMobile.ViewModels"
             xmlns:models="clr-namespace:ForkFeedMobile.Models"
             xmlns:icons="clr-namespace:MauiIcons.FluentFilled;assembly=MauiIcons.FluentFilled"
             xmlns:controls="clr-namespace:ForkFeedMobile.Controls"
             x:Class="ForkFeedMobile.Views.RecipeDetailPage"
             x:DataType="vm:RecipeDetailViewModel"
             Title="Recept"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource NavBarBackground}}">

    <Grid>
    <ScrollView IsVisible="{Binding IsNotLoading}">
        <Grid RowDefinitions="Auto,*">

            <!-- Error -->
            <VerticalStackLayout Grid.Row="0"
                                 IsVisible="{Binding HasError}"
                                 Padding="20" Spacing="10"
                                 VerticalOptions="Center" HorizontalOptions="Center">
                <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource ErrorRed}"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Content -->
            <VerticalStackLayout Grid.Row="1" Spacing="0"
                                 IsVisible="{Binding IsRecipeLoaded}">

                <!-- Hero Image -->
                <Image Source="{Binding Recipe.ImageUrl}"
                       Aspect="AspectFit"/>

                <VerticalStackLayout Padding="16" Spacing="12">

                    <!-- Author -->
                    <HorizontalStackLayout Spacing="10">
                        <HorizontalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding AuthorTappedCommand}" />
                        </HorizontalStackLayout.GestureRecognizers>

                        <controls:AvatarView ImageUrl="{Binding Recipe.AuthorProfileImageUrl}"
                                              UserName="{Binding Recipe.AuthorUsername}"
                                              Size="36" />

                        <Label Text="{Binding Recipe.AuthorUsername}"
                               FontSize="15" FontAttributes="Bold"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <!-- Title -->
                    <Label Text="{Binding Recipe.Title}"
                           FontSize="24" FontAttributes="Bold" />

                    <!-- Description -->
                    <Label Text="{Binding Recipe.Description}"
                           FontSize="15" TextColor="{StaticResource Gray500}"
                           LineBreakMode="WordWrap" />

                        <!-- Action Buttons Row -->
                    <HorizontalStackLayout Spacing="16">
                        <!-- Favorite -->
                        <icons:MauiIcon Icon="{Binding Recipe.IsFavorite, Converter={StaticResource FavoriteIcon}}"
                               IconColor="{Binding Recipe.IsFavorite, Converter={StaticResource FavoriteColor}}"
                               IconSize="26" VerticalOptions="Center">
                            <icons:MauiIcon.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleFavoriteCommand}" />
                            </icons:MauiIcon.GestureRecognizers>
                        </icons:MauiIcon>

                        <!-- Share -->
                        <icons:MauiIcon Icon="ShareIos24Filled" IconSize="24" VerticalOptions="Center"
                                        IconColor="{AppThemeBinding Light={StaticResource PrimaryTextColorLight}, Dark={StaticResource PrimaryTextColorDark}}">
                            <icons:MauiIcon.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ShareRecipeCommand}" />
                            </icons:MauiIcon.GestureRecognizers>
                        </icons:MauiIcon>

                        <!-- Save to Cookbook -->
                        <icons:MauiIcon Icon="Book24Filled" IconSize="24" VerticalOptions="Center"
                                        IconColor="{AppThemeBinding Light={StaticResource PrimaryTextColorLight}, Dark={StaticResource PrimaryTextColorDark}}">
                            <icons:MauiIcon.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SaveToCookbookCommand}" />
                            </icons:MauiIcon.GestureRecognizers>
                        </icons:MauiIcon>

                        <!-- Report -->
                        <icons:MauiIcon Icon="Warning28Filled" IconSize="24" VerticalOptions="Center"
                                        IconColor="{AppThemeBinding Light={StaticResource PrimaryTextColorLight}, Dark={StaticResource PrimaryTextColorDark}}">
                            <icons:MauiIcon.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ReportRecipeCommand}" />
                            </icons:MauiIcon.GestureRecognizers>
                        </icons:MauiIcon>
                    </HorizontalStackLayout>

                    <!-- Meta info -->
                    <HorizontalStackLayout Spacing="16">
                        <Border StrokeShape="RoundRectangle 12"
                                Stroke="{Binding Recipe.DifficultyBorderColor}"
                                BackgroundColor="{Binding Recipe.DifficultyBackgroundColor}"
                                Padding="10,4"
                                StrokeThickness="1.5"
                                VerticalOptions="Center">
                            <Label Text="{Binding Recipe.DifficultyDisplay}"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="White" />
                        </Border>
                        <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
                            <icons:MauiIcon Icon="Timer24Filled" IconSize="14" IconColor="{StaticResource Gray500}" VerticalOptions="Center" />
                            <Label VerticalOptions="Center" FontSize="14" TextColor="{StaticResource Gray500}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding Recipe.TimeMinutes}" />
                                        <Span Text=" perc" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
                            <icons:MauiIcon Icon="Star12Filled" IconSize="14" IconColor="{StaticResource StarFilled}" VerticalOptions="Center" />
                            <Label VerticalOptions="Center" FontSize="14" TextColor="{StaticResource StarFilled}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding Recipe.Rating, StringFormat='{0:F1}'}" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </HorizontalStackLayout>
                    </HorizontalStackLayout>

                    <!-- Rating Stars -->
                    <VerticalStackLayout Spacing="4" Margin="0,4,0,0"
                                         IsEnabled="{Binding IsSubmittingRating, Converter={StaticResource InvertBool}}">
                        <Label Text="Te értékelésed" FontSize="14" TextColor="{StaticResource Gray500}" />
                        <HorizontalStackLayout Spacing="4">
                            <icons:MauiIcon Icon="Star12Filled" IconSize="28"
                                   IconColor="{Binding UserRating, Converter={StaticResource RatingStarColor}, ConverterParameter=1}">
                                <icons:MauiIcon.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SetRatingCommand}" CommandParameter="1" />
                                </icons:MauiIcon.GestureRecognizers>
                            </icons:MauiIcon>
                            <icons:MauiIcon Icon="Star12Filled" IconSize="28"
                                   IconColor="{Binding UserRating, Converter={StaticResource RatingStarColor}, ConverterParameter=2}">
                                <icons:MauiIcon.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SetRatingCommand}" CommandParameter="2" />
                                </icons:MauiIcon.GestureRecognizers>
                            </icons:MauiIcon>
                            <icons:MauiIcon Icon="Star12Filled" IconSize="28"
                                   IconColor="{Binding UserRating, Converter={StaticResource RatingStarColor}, ConverterParameter=3}">
                                <icons:MauiIcon.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SetRatingCommand}" CommandParameter="3" />
                                </icons:MauiIcon.GestureRecognizers>
                            </icons:MauiIcon>
                            <icons:MauiIcon Icon="Star12Filled" IconSize="28"
                                   IconColor="{Binding UserRating, Converter={StaticResource RatingStarColor}, ConverterParameter=4}">
                                <icons:MauiIcon.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SetRatingCommand}" CommandParameter="4" />
                                </icons:MauiIcon.GestureRecognizers>
                            </icons:MauiIcon>
                            <icons:MauiIcon Icon="Star12Filled" IconSize="28"
                                   IconColor="{Binding UserRating, Converter={StaticResource RatingStarColor}, ConverterParameter=5}">
                                <icons:MauiIcon.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SetRatingCommand}" CommandParameter="5" />
                                </icons:MauiIcon.GestureRecognizers>
                            </icons:MauiIcon>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    

                    <!-- Ingredients Section -->
                    <Label Text="Hozzávalók" FontSize="20" FontAttributes="Bold" Margin="0,4,0,0" />

                    <CollectionView ItemsSource="{Binding Ingredients}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Ingredient">
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,4" ColumnSpacing="8">
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsChecked}"
                                              Color="{StaticResource Primary}" />
                                    <Label Grid.Column="1" Text="{Binding Name}"
                                           VerticalOptions="Center" FontSize="15" />
                                    <Label Grid.Column="2" Text="{Binding DisplayQuantity}"
                                           VerticalOptions="Center" FontSize="14"
                                           TextColor="{StaticResource Gray400}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Add to Shopping List Button -->
                    <Button Text="Hozzáadás bevásárlólistához"
                            Command="{Binding GoToShoppingListCommand}"
                            IsVisible="{Binding HasSelectedIngredients}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            FontSize="16" FontAttributes="Bold"
                            CornerRadius="12"
                            HeightRequest="48"
                            Margin="0,8,0,0" />

                    <!-- Steps Section -->
                    <Label Text="Elkészítés" FontSize="20" FontAttributes="Bold" Margin="0,8,0,0" />

                    <CollectionView ItemsSource="{Binding Steps}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:RecipeStep">
                                <HorizontalStackLayout Spacing="10" Padding="0,6">
                                    <Frame WidthRequest="32" HeightRequest="32" CornerRadius="16"
                                           BackgroundColor="{StaticResource Primary}" Padding="0"
                                           BorderColor="Transparent">
                                        <Label Text="{Binding StepNumber}" TextColor="White"
                                               FontSize="14" FontAttributes="Bold"
                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Frame>
                                    <Label Text="{Binding Description}" FontSize="15"
                                           VerticalOptions="Center" LineBreakMode="WordWrap"
                                           MaximumWidthRequest="300" />
                                </HorizontalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Start Cooking Button -->
                    <Button Text="Főzés kezdése"
                            Command="{Binding StartCookingCommand}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            FontSize="18" FontAttributes="Bold"
                            CornerRadius="12"
                            HeightRequest="56"
                            Margin="0,16,0,8" />

                    <!-- Comments Section -->
                    <Label Text="Hozzászólások" FontSize="20" FontAttributes="Bold" Margin="0,8,0,4" />

                    <!-- Comment Input -->
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Margin="0,0,0,8">
                        <Entry Grid.Column="0"
                               Placeholder="Írj egy kommentet..."
                               Text="{Binding NewCommentText}"
                               FontSize="14"
                               ReturnType="Send"
                               ReturnCommand="{Binding PostCommentCommand}"
                               IsEnabled="{Binding IsPostingComment, Converter={StaticResource InvertBool}}" />
                        <Button Grid.Column="1"
                                Text="Küld"
                                Command="{Binding PostCommentCommand}"
                                IsEnabled="{Binding IsPostingComment, Converter={StaticResource InvertBool}}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                FontSize="14"
                                CornerRadius="8"
                                Padding="12,0"
                                HeightRequest="44" />
                    </Grid>

                    <!-- No Comments Message -->
                    <Label Text="Nincsenek hozzászólások."
                           IsVisible="{Binding HasNoComments}"
                           FontSize="14"
                           TextColor="{StaticResource Gray400}"
                           HorizontalTextAlignment="Center"
                           Margin="0,8" />

                    <!-- Comments List -->
                    <CollectionView ItemsSource="{Binding Comments}" SelectionMode="None" Margin="0,0,0,80">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Comment">
                                <VerticalStackLayout Padding="0,8" Spacing="4">
                                    <Grid ColumnDefinitions="36,*,Auto" ColumnSpacing="10">
                                        <!-- Profile Image -->
                                        <controls:AvatarView Grid.Column="0"
                                                              ImageUrl="{Binding ProfileImageUrl}"
                                                              UserName="{Binding Username}"
                                                              Size="36"
                                                              VerticalOptions="Start">
                                            <controls:AvatarView.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RecipeDetailViewModel}}, Path=CommentAuthorTappedCommand}"
                                                                      CommandParameter="{Binding}" />
                                            </controls:AvatarView.GestureRecognizers>
                                        </controls:AvatarView>

                                        <!-- Username + Timestamp -->
                                        <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                            <Label Text="{Binding Username}"
                                                   FontSize="14" FontAttributes="Bold"
                                                   VerticalOptions="Center">
                                                <Label.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RecipeDetailViewModel}}, Path=CommentAuthorTappedCommand}"
                                                                          CommandParameter="{Binding}" />
                                                </Label.GestureRecognizers>
                                            </Label>
                                            <Label Text="{Binding CreatedAt, Converter={StaticResource DateTimeToRelative}}"
                                                   FontSize="12" TextColor="{StaticResource Gray400}"
                                                   VerticalOptions="Center" />
                                        </HorizontalStackLayout>

                                        <!-- Delete & Report Buttons -->
                                        <HorizontalStackLayout Grid.Column="2" Spacing="8" VerticalOptions="Center">
                                            <!-- Delete Button (own comments only) -->
                                            <icons:MauiIcon Icon="Delete28Filled"
                                                            IconSize="24"
                                                            IconColor="{StaticResource ErrorRed}"
                                                            IsVisible="{Binding IsOwnComment}">
                                                <icons:MauiIcon.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RecipeDetailViewModel}}, Path=DeleteCommentCommand}"
                                                                          CommandParameter="{Binding}" />
                                                </icons:MauiIcon.GestureRecognizers>
                                            </icons:MauiIcon>

                                            <!-- Report Button -->
                                            <icons:MauiIcon Icon="Warning28Filled"
                                                            IconSize="24"
                                                            IconColor="{StaticResource Gray400}">
                                                <icons:MauiIcon.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RecipeDetailViewModel}}, Path=ReportCommentCommand}"
                                                                          CommandParameter="{Binding}" />
                                                </icons:MauiIcon.GestureRecognizers>
                                            </icons:MauiIcon>
                                        </HorizontalStackLayout>
                                    </Grid>

                                    <!-- Comment Text -->
                                    <Label Text="{Binding Text}"
                                           FontSize="14"
                                           LineBreakMode="WordWrap"
                                           Margin="46,0,0,0" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
    <!-- Centered Loading Overlay -->
    <controls:LoadingOverlay IsVisible="{Binding IsLoading}" />
    <controls:FloatingNavBar />
    </Grid>
</ContentPage>
