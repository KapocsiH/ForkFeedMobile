<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ForkFeedMobile.ViewModels"
             xmlns:icons="clr-namespace:MauiIcons.FluentFilled;assembly=MauiIcons.FluentFilled"
             x:Class="ForkFeedMobile.Views.ForgotPasswordPage"
             x:DataType="vm:ForgotPasswordViewModel"
             Title="Elfelejtett jelszó"
             Shell.NavBarIsVisible="True"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource NavBarBackground}}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="14">

            <icons:MauiIcon Icon="LockClosed24Filled" IconSize="60" HorizontalOptions="Center" Margin="0,20,0,0" />
            <Label Text="Jelszó visszaállítása"
                   FontSize="24" FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />

            <!-- Step 1: Request reset link -->
            <VerticalStackLayout IsVisible="{Binding ShowResetForm, Converter={StaticResource InvertBool}}"
                                 Spacing="14">
                <Label Text="Add meg az email címet amire elküldhetjük a jelszó visszaállító emailt."
                       FontSize="14" TextColor="{StaticResource Gray400}"
                       HorizontalTextAlignment="Center" Margin="0,0,0,8" />

                <Entry Placeholder="Email" Text="{Binding Email}" Keyboard="Email" />

                <Label Text="{Binding FormError}"
                       TextColor="{StaticResource ErrorRed}"
                       FontSize="13"
                       IsVisible="{Binding FormError, Converter={StaticResource StringNotEmpty}}"
                       HorizontalTextAlignment="Center" />

                <Button Text="Link küldése"
                        Command="{Binding SendResetLinkCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        CornerRadius="12" HeightRequest="50"
                        FontSize="18" FontAttributes="Bold" />
            </VerticalStackLayout>

            <!-- Step 2: Enter token and new password -->
            <VerticalStackLayout IsVisible="{Binding ShowResetForm}" Spacing="14">
                <Label Text="Add meg a visszaállítási tokent, majd adj meg egy új jelszót."
                       FontSize="14" TextColor="{StaticResource Gray400}"
                       HorizontalTextAlignment="Center" Margin="0,0,0,8" />

                <Entry Placeholder="Visszaállítási token" Text="{Binding ResetToken}" />
                <Entry Placeholder="Új jelszó" Text="{Binding NewPassword}" IsPassword="True" />
                <Entry Placeholder="Új jelszó megerősítése" Text="{Binding ConfirmNewPassword}" IsPassword="True" />

                <Label Text="{Binding FormError}"
                       TextColor="{StaticResource ErrorRed}"
                       FontSize="13"
                       IsVisible="{Binding FormError, Converter={StaticResource StringNotEmpty}}"
                       HorizontalTextAlignment="Center" />

                <Button Text="Jelszó visszaállítása"
                        Command="{Binding ResetPasswordCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        CornerRadius="12" HeightRequest="50"
                        FontSize="18" FontAttributes="Bold" />
            </VerticalStackLayout>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Primary}" />

            <Button Text="Vissza a bejelentkezéshez"
                    Command="{Binding GoBackCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Primary}"
                    FontSize="14"
                    Padding="0"
                    HeightRequest="40" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
