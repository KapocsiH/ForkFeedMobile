<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ForkFeedMobile.Controls.FloatingNavBar"
             VerticalOptions="End"
             HorizontalOptions="Fill"
             Margin="20,0,20,20"
             InputTransparent="False">

    <Border StrokeShape="RoundRectangle 35"
            BackgroundColor="{StaticResource NavBarBackground}"
            Padding="8,0"
            StrokeThickness="0"
            HeightRequest="70">
        <Border.Shadow>
            <Shadow Brush="Black" Offset="0,6" Radius="24" Opacity="0.5" />
        </Border.Shadow>

        <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="0">

            <!-- Tab 0: Home -->
            <Grid Grid.Column="0" ClassId="0"
                  VerticalOptions="Center" HorizontalOptions="Center"
                  WidthRequest="56" HeightRequest="56">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTabTapped" />
                </Grid.GestureRecognizers>
                <!-- Subtle circle background -->
                <Ellipse WidthRequest="48" HeightRequest="48"
                         Fill="#15FFFFFF"
                         HorizontalOptions="Center" VerticalOptions="Center" />
                <!-- Active glow -->
                <Ellipse x:Name="Glow0" WidthRequest="50" HeightRequest="50"
                         HorizontalOptions="Center" VerticalOptions="Center"
                         IsVisible="True">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#CC422AD5" Offset="0.0" />
                            <GradientStop Color="#66422AD5" Offset="0.5" />
                            <GradientStop Color="#00422AD5" Offset="1.0" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <!-- Icon: Home -->
                <Path x:Name="Icon0"
                      Data="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"
                      Fill="White"
                      Aspect="Uniform" WidthRequest="24" HeightRequest="24"
                      HorizontalOptions="Center" VerticalOptions="Center" />
            </Grid>

            <!-- Tab 1: Shopping -->
            <Grid Grid.Column="1" ClassId="1"
                  VerticalOptions="Center" HorizontalOptions="Center"
                  WidthRequest="56" HeightRequest="56">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTabTapped" />
                </Grid.GestureRecognizers>
                <Ellipse WidthRequest="48" HeightRequest="48"
                         Fill="#15FFFFFF"
                         HorizontalOptions="Center" VerticalOptions="Center" />
                <Ellipse x:Name="Glow1" WidthRequest="50" HeightRequest="50"
                         HorizontalOptions="Center" VerticalOptions="Center"
                         IsVisible="False">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#CC422AD5" Offset="0.0" />
                            <GradientStop Color="#66422AD5" Offset="0.5" />
                            <GradientStop Color="#00422AD5" Offset="1.0" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <!-- Icon: Cart -->
                <Path x:Name="Icon1"
                      Data="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49A1 1 0 0 0 20.42 4H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"
                      Fill="#55FFFFFF"
                      Aspect="Uniform" WidthRequest="24" HeightRequest="24"
                      HorizontalOptions="Center" VerticalOptions="Center" />
            </Grid>

            <!-- Tab 2: Add -->
            <Grid Grid.Column="2" ClassId="2"
                  VerticalOptions="Center" HorizontalOptions="Center"
                  WidthRequest="56" HeightRequest="56">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTabTapped" />
                </Grid.GestureRecognizers>
                <Ellipse WidthRequest="48" HeightRequest="48"
                         Fill="#15FFFFFF"
                         HorizontalOptions="Center" VerticalOptions="Center" />
                <Ellipse x:Name="Glow2" WidthRequest="50" HeightRequest="50"
                         HorizontalOptions="Center" VerticalOptions="Center"
                         IsVisible="False">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#CC422AD5" Offset="0.0" />
                            <GradientStop Color="#66422AD5" Offset="0.5" />
                            <GradientStop Color="#00422AD5" Offset="1.0" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <!-- Icon: Plus -->
                <Path x:Name="Icon2"
                      Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"
                      Fill="#55FFFFFF"
                      Aspect="Uniform" WidthRequest="22" HeightRequest="22"
                      HorizontalOptions="Center" VerticalOptions="Center" />
            </Grid>

            <!-- Tab 3: Favorites -->
            <Grid Grid.Column="3" ClassId="3"
                  VerticalOptions="Center" HorizontalOptions="Center"
                  WidthRequest="56" HeightRequest="56">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTabTapped" />
                </Grid.GestureRecognizers>
                <Ellipse WidthRequest="48" HeightRequest="48"
                         Fill="#15FFFFFF"
                         HorizontalOptions="Center" VerticalOptions="Center" />
                <Ellipse x:Name="Glow3" WidthRequest="50" HeightRequest="50"
                         HorizontalOptions="Center" VerticalOptions="Center"
                         IsVisible="False">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#CC422AD5" Offset="0.0" />
                            <GradientStop Color="#66422AD5" Offset="0.5" />
                            <GradientStop Color="#00422AD5" Offset="1.0" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <!-- Icon: Heart -->
                <Path x:Name="Icon3"
                      Data="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
                      Fill="#55FFFFFF"
                      Aspect="Uniform" WidthRequest="24" HeightRequest="24"
                      HorizontalOptions="Center" VerticalOptions="Center" />
            </Grid>

            <!-- Tab 4: Profile -->
            <Grid Grid.Column="4" ClassId="4"
                  VerticalOptions="Center" HorizontalOptions="Center"
                  WidthRequest="56" HeightRequest="56">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTabTapped" />
                </Grid.GestureRecognizers>
                <Ellipse WidthRequest="48" HeightRequest="48"
                         Fill="#15FFFFFF"
                         HorizontalOptions="Center" VerticalOptions="Center" />
                <Ellipse x:Name="Glow4" WidthRequest="50" HeightRequest="50"
                         HorizontalOptions="Center" VerticalOptions="Center"
                         IsVisible="False">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#CC422AD5" Offset="0.0" />
                            <GradientStop Color="#66422AD5" Offset="0.5" />
                            <GradientStop Color="#00422AD5" Offset="1.0" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <!-- Icon: Person -->
                <Path x:Name="Icon4"
                      Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"
                      Fill="#55FFFFFF"
                      Aspect="Uniform" WidthRequest="24" HeightRequest="24"
                      HorizontalOptions="Center" VerticalOptions="Center" />
            </Grid>

        </Grid>
    </Border>
</ContentView>
